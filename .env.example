NODE_ENV=production
PORT=5000

# MongoDB Connection String
MONGODB_URI=your_mongodb_uri_here

# Bland AI (for voice calls) - Get from https://bland.ai
BLAND_AI_API_KEY=your_bland_ai_api_key_here
TEST_PHONE_NUMBER=919999999999

# WhatsApp Business API (Meta)
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
META_ACCESS_TOKEN=your_meta_access_token_here
META_WA_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
META_WA_ACCESS_TOKEN=your_meta_access_token_here
META_WA_API_VERSIONS=v22.0,v21.0,v20.0,v19.0,v18.0
META_WA_API_VERSION=v22.0
META_WA_TEMPLATE_NAME_ORDER=order_confirmation__bill
META_WA_TEMPLATE_LANGS=en,en_US,en_IN
META_WA_TEMPLATE_NAME_START=hello_world
META_WA_TEMPLATE_LANG_START=en_US
META_WA_MAX_ATTEMPTS=24
META_WA_WEBHOOK_VERIFY_TOKEN=your_whatsapp_webhook_verify_token_here
META_WEBHOOK_VERIFY_TOKEN=your_whatsapp_webhook_verify_token_here
META_ENFORCE_SIGNATURE=false
# Optional (for X-Hub-Signature-256 verification)
META_WEBHOOK_APP_SECRET=your_meta_app_secret_here

# Groq AI (for WhatsApp chatbot) - Get from https://groq.com
GROQ_API_KEY=your_groq_api_key_here

# Eleven Labs (Native Conversational AI)
ELEVEN_LABS_API_KEY=your_key_here
ELEVEN_LABS_AGENT_ID=your_agent_id_here

# Indian Telephony (SIP Trunk)
SIP_DOMAIN=your_provider_domain_here
SIP_USERNAME=your_sip_username_here
SIP_PASSWORD=your_sip_password_here

# Admin Dashboard Security
ADMIN_PASSWORD=admin123
SECRET_KEY=your_super_secret_key_here
# Optional aliases supported by code:
# ADMIN_SECRET=admin123
# JWT_SECRET=your_super_secret_key_here

# Optional: comma-separated dashboard domains (or '*' to allow all)
ALLOWED_ORIGINS=https://your-service.onrender.com
